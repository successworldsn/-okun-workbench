# Supabase (project: okun-workbench, id mdxhwvfnyppchxkgrvus, region us-east-1)
SUPABASE_URL=https://mdxhwvfnyppchxkgrvus.supabase.co
# Service-role secret key — Supabase dashboard > Project Settings > API > service_role.
# Server-only, never sent to the browser. Not fetchable via MCP by design.
# IMPORTANT: without both this and SUPABASE_URL set, DEMO_MODE is on, which
# means middleware.ts BYPASSES LOGIN ENTIRELY. Auth only actually enforces
# once real Supabase creds are here — don't deploy without them.
SUPABASE_SERVICE_ROLE_KEY=

# Signs the login session cookie (Web Crypto HMAC, see lib/session.ts). Any
# long random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Twilio (7am SMS digest — Module 0 / Global Rule 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Where the daily digest gets sent (EJ's phone, E.164 format)
DIGEST_TO_NUMBER=

# Shared secret sent as the x-digest-secret header by n8n → /api/digest,
# /api/ssf/stock-feed-guard, and /api/webhooks/ebay-order. Generate any long
# random string. Same secret across all three — no reason to split it yet.
DIGEST_SECRET=

# Resend (email — roadmap, Phase C briefings)
RESEND_API_KEY=

# Claude API (provider-agnostic wrapper — SSF listing drafter)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# eBay production API — Module 2b/2c/2d/2e. THE LONG POLE. Apply day one;
# nothing publishes, ends, or uploads tracking for real until these are set.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_REFRESH_TOKEN=
# eBay Browse API — live active-listing counts for the demand-gap scanner.
# Same keyset/approval as above; the scanner works from Terapeak CSV alone
# without this, this is a cross-check layer only.

# eBay Marketplace Account Deletion webhook (/api/webhooks/ebay-account-deletion)
# — required for eBay to enable a new production keyset at all. Generate any
# 32-80 char alphanumeric string; register the same value + this app's
# deployed URL in the eBay Developer Portal (Application Keys > Notifications).
EBAY_VERIFICATION_TOKEN=

# SSF channel economics (all optional — sane defaults in lib/ssf-config.ts)
SSF_EBAY_FEE_PCT=0.136
SSF_PROMO_PCT=0.03
SSF_SHIPPING_ESTIMATE=12
SSF_MARGIN_FLOOR_PCT=0.10
SSF_STALE_AMBER_DAYS=7
SSF_STALE_BLOCK_DAYS=14
SSF_HANDLING_DAYS=3
# Comma-separated overrides
SSF_NICHE_BRANDS=land rover,range rover,jaguar,volvo,porsche
SSF_COMMODITY_KEYWORDS=oil filter,air filter,cabin filter,wiper,spark plug,brake pad,brake pads,serpentine belt,cabin air filter
SSF_VERO_REVIEW_BRANDS=bmw,mercedes,mercedes-benz,porsche
